{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "cy:open": "cypress open",
        "cy:run": "cypress run",
        "test": "concurrently --kill-others --success=first \"php artisan serve\" \"cross-env NODE_ENV=test LARAVEL_BYPASS_ENV_CHECK=1 vite\" \"sleep 5 && cross-env NODE_ENV=test cypress run --headless --browser chrome\""
    },
    "devDependencies": {
        "@cypress/code-coverage": "^4.0.3",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "cross-env": "^10.1.0",
        "cypress": "^15.16.0",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7",
        "vite-plugin-istanbul": "^9.0.1"
    }
}
